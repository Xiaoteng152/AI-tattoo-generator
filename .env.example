DATABASE_URL="postgresql://growth:growth@localhost:5432/growth_harness?schema=public"
DIRECT_URL="postgresql://growth:growth@localhost:5432/growth_harness?schema=public"
# Optional: Supabase pooler can take ~1s on cold connect in dev
# DATABASE_PROBE_TIMEOUT_MS="2500"
# DATABASE_QUERY_TIMEOUT_MS="3000"
REDIS_URL="redis://localhost:6379"

# Auth.js — Google OAuth (required for DeepSearch)
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""
# Official Auth.js v5 names (recommended):
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Legacy aliases also supported by src/auth.ts:
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Optional; defaults to request host in dev when trustHost is enabled
AUTH_URL="http://localhost:3000"
# Optional; Node OAuth requests use this when Google endpoints are blocked locally
# HTTPS_PROXY="http://127.0.0.1:7890"

# Used by the protected sync endpoint and by either Cloudflare Worker Cron or Vercel Cron.
# Configure the same secret on the chosen scheduler; enable only one scheduler per environment.
CRON_SECRET=""

# Connector mode:
# - mock: use bundled demo data only
# - real: require real connectors, fail if a configured provider is missing
# - hybrid: use real Reddit, SoPilot-backed X/Twitter, and real Etsy when ETSY_API_KEY exists
CONNECTORS_MODE="hybrid"

# Reddit public JSON search works without OAuth for the MVP.

# X/Twitter source:
# - sopilot: use public SoPilot hot tweets RSS
# - x-api: use official X API v2 Recent Search
TWITTER_SOURCE="x-api"
SOPILOT_HOT_TWEETS_URL="https://sopilot.net/rss/hottweets"

# X/Twitter API v2 Bearer Token. Required for Workflow X search and Trading Radar creator timelines.
# Trading Radar never falls back to SoPilot because a hot-post feed cannot guarantee creator coverage.
X_BEARER_TOKEN=""

# Workflow X extraction defaults
WORKFLOW_X_LIMIT_PER_SOURCE="40"
WORKFLOW_X_MAX_PAGES="5"
WORKFLOW_SOPILOT_MIN_RESULTS="10"

# Optional: route outbound API calls (X API, Google OAuth) through a local proxy
# HTTPS_PROXY="http://127.0.0.1:7897"

# When X API returns 401/403, fall back to SoPilot RSS with strict keyword matching.
# Set to "none" to disable fallback and surface X API errors directly.
# TWITTER_AUTH_FALLBACK="sopilot"

# Etsy Open API v3 keystring. Required for real Etsy connector.
ETSY_API_KEY=""

# AI enrichment. Growth workflows may fall back to rules, but Trading Radar never generates fallback signals.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
ENRICHMENT_MODE="ai"
ENRICHMENT_STRICT="false"

# Trading Radar Telegram delivery. Both values are required to push explicit signals.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
