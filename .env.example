DATABASE_URL="postgresql://growth:growth@localhost:5432/growth_harness?schema=public"
REDIS_URL="redis://localhost:6379"

# Connector mode:
# - mock: use bundled demo data only
# - real: require real connectors, fail if a configured provider is missing
# - hybrid: use real Reddit and real Etsy when ETSY_API_KEY exists, otherwise mock Etsy
CONNECTORS_MODE="hybrid"

# Reddit public JSON search works without OAuth for the MVP.

# Etsy Open API v3 keystring. Required for real Etsy connector.
ETSY_API_KEY=""

# AI enrichment. If OPENAI_API_KEY is empty, the app falls back to local rule-based analysis.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
ENRICHMENT_MODE="ai"
ENRICHMENT_STRICT="false"
