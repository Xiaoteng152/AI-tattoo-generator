{
  "name": "ai-tattoo-generator",
  "version": "1.0.0",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && npm run typecheck:worker",
    "typecheck:worker": "tsc --noEmit -p workers/trading-radar-cron/tsconfig.json",
    "test": "node --import tsx --test src/modules/deepsearch/__tests__/*.test.ts src/modules/trading-radar/__tests__/*.test.ts workers/trading-radar-cron/test/*.test.ts",
    "test:deepsearch": "node --import tsx --test src/modules/deepsearch/__tests__/*.test.ts",
    "test:trading-radar": "node --import tsx --test src/modules/trading-radar/__tests__/*.test.ts",
    "test:worker": "node --import tsx --test workers/trading-radar-cron/test/*.test.ts",
    "worker:dev": "wrangler dev --config workers/trading-radar-cron/wrangler.toml --test-scheduled",
    "worker:dry-run": "wrangler deploy --dry-run --config workers/trading-radar-cron/wrangler.toml",
    "worker:check": "npm run test:worker && npm run typecheck:worker && npm run worker:dry-run",
    "worker:deploy": "wrangler deploy --config workers/trading-radar-cron/wrangler.toml",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "hooks:install": "cp .githooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Growth Automation Harness MVP：以 AI tattoo generator 为演示垂类，聚合 Reddit/X/Etsy 信号并生成 SEO brief 与 DeepSearch 研究报告。",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.76.8",
    "ioredis": "^5.10.1",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "undici": "^7.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260716.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "wrangler": "4.111.0"
  }
}
